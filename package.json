{
  "name": "humanify",
  "version": "1.0.0",
  "description": "A tool for improving minified JavaScript code",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "start": "tsx src/index.ts",
    "debug": "node --inspect-brk ./node_modules/.bin/tsx src/index.ts",
    "build": "pkgroll",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "tsc --noEmit"
  },
  "bin": {
    "humanify": "dist/index.mjs"
  },
  "keywords": [
    "javascript",
    "minification",
    "readability"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "dotenv": "^16.3.1",
    "mongodb-memory-server": "^9.1.1",
    "mongoose": "^8.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "cleye": "^1.3.4",
    "jest": "^29.7.0",
    "pkgroll": "^2.4.2",
    "ts-jest": "^29.2.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.8"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jehna/humanify.git"
  },
  "bugs": {
    "url": "https://github.com/jehna/humanify/issues"
  },
  "homepage": "https://github.com/jehna/humanify#readme"
}
