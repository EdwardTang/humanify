{
    "name": "guangbiao-research",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.10"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },
    "forwardPorts": [8080, 27017],
    "postCreateCommand": "echo 'MongoDB connection is available at mongodb://root:example@mongodb:27017/'"
}